# money-and-mode.com — API Credentials Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git — it's in .gitignore

# ── WordPress ──────────────────────────────────────────────────────────────────
WP_SITE_URL=https://money-and-mode.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Pinterest ──────────────────────────────────────────────────────────────────
# Get from: https://developers.pinterest.com/apps/
# Steps: Create App → Generate User Token → Scopes: boards:read, pins:write
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here

# ── Twitter / X ────────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/projects
# For search only (free tier): just the Bearer Token is enough
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# For posting tweets (requires Basic plan $100/month or higher):
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ── Instagram ──────────────────────────────────────────────────────────────────
# Instagram posting requires Facebook Business account + Meta Developer App
# Get from: https://developers.facebook.com/apps/
# Requires: Instagram Graph API, pages_read_engagement, instagram_content_publish
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
